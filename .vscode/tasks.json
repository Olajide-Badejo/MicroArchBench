{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B", "build",
                "-DCMAKE_BUILD_TYPE=Release",
                "-DBENCH_ENABLE_AVX2=ON",
                "-DBENCH_ENABLE_FMA=ON",
                "-DBENCH_ENABLE_PERF=ON",
                "-DBENCHMARK_DOWNLOAD_DEPENDENCIES=ON",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
                "-G", "Ninja"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake: build",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build", "-j${input:nproc}"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "CMake: clean",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build", "--target", "clean"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Run: ctest",
            "type": "shell",
            "command": "ctest",
            "args": ["--test-dir", "build", "-V"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Run: full suite",
            "type": "shell",
            "command": "bash",
            "args": ["scripts/run_suite.sh", "--no-freq-lock"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Run: check system",
            "type": "shell",
            "command": "bash",
            "args": ["scripts/check_system.sh"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Python: install deps",
            "type": "shell",
            "command": "pip3",
            "args": ["install", "-r", "requirements.txt"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "nproc",
            "type": "promptString",
            "description": "Number of parallel build jobs",
            "default": "4"
        }
    ]
}
