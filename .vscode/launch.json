{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "pointer_chase (Release)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/pointer_chase",
            "args": [
                "--benchmark_format=console",
                "--benchmark_repetitions=3",
                "--benchmark_min_warmup_time=0.5"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake: build"
        },
